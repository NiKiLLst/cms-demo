<!DOCTYPE html>
<html lang="{{@site.locale}}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{meta_title}}</title>
    {{!-- {{ghost_head}} emits its own meta description; the manual tag was a Ghost 4-era duplicate. --}}
    {{ghost_head}}
    {{!-- Inline stylesheet keeps the theme one-folder simple for the demo. --}}
    <link rel="stylesheet" href="{{asset "css/style.css"}}">
</head>
<body class="{{body_class}}">
    <nav class="site-nav">
        <span class="brand"><a href="{{@site.url}}">cms-demo</a></span>
        <a href="{{@site.url}}/">Home</a>
        <a href="{{@site.url}}/blog/">Blog</a>
        <a href="{{@site.url}}/portfolio/">Portfolio</a>
        <a href="{{@site.url}}/prenotazioni/">Prenotazioni</a>
        <a class="admin-link" href="{{@site.url}}/ghost/">Admin</a>
    </nav>

    <main class="site-main">
        {{{body}}}
    </main>

    <footer class="site-footer">
        powered by Ghost · only /blog is implemented natively (validation outcome)
    </footer>
    {{ghost_foot}}
</body>
</html>
