# Ghost public URL (use http:// behind Cloudflare Tunnel — TLS at edge)
GHOST_URL=https://ghost.example.com

# MySQL
MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE=ghost
MYSQL_USER=ghost
MYSQL_PASSWORD=change-me

# SMTP: not configured by default. To enable member magic links / staff invites,
# add a Mail config block in apps/ghost/docker-compose.yml under the ghost
# service environment, e.g.:
#   mail__transport: SMTP
#   mail__options__service: Mailgun
#   mail__options__host: smtp.eu.mailgun.org
#   ...
