# Appwrite API endpoint (v1). For the cms-demo deployment Appwrite admin lives
# on appwrite.nerdass.org (NOT renamed because _APP_DOMAIN is baked into the
# instance — see plan).
CMS_URL=http://appwrite.nerdass.org/v1

# Project ID created in Appwrite Console after first deploy. Must match the
# projectId in apps/appwrite/appwrite.json.
APPWRITE_PROJECT_ID=cms-demo

# Database ID inside the project — must match apps/appwrite/appwrite.json.
APPWRITE_DATABASE_ID=main

CMS_NAME=Appwrite
